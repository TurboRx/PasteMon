# =============================================================================
# PasteMon — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.

# PostgreSQL connection string (required)
#
# Free cloud options:
#   Neon     → https://neon.tech       (serverless, free tier)
#   Supabase → https://supabase.com    (free tier with extras)
#   Railway  → https://railway.app     (easy managed Postgres)
#
# Local Docker option (see docker-compose.yml):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pastemon"
#
DATABASE_URL="postgresql://user:password@host:5432/pastemon?sslmode=require"
